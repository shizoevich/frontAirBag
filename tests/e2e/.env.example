# ─── Site ─────────────────────────────────────────────────────────────────────
# URL of the running site (no trailing slash)
SITE_URL=https://dev.airbagad.com

# Locale prefix used in every URL  (en | ru | uk)
LOCALE=ru

# ─── Test accounts ────────────────────────────────────────────────────────────
# A regular test account (no Telegram linked)
SITE_TEST_EMAIL=test@example.com
SITE_TEST_PASSWORD=testpassword123

# A test account that already has a Telegram ID linked
# Used in test 02 (auto-auth as real user)
SITE_LINKED_EMAIL=linked@example.com
SITE_LINKED_PASSWORD=linkedpassword123

# ─── Telegram bot ─────────────────────────────────────────────────────────────
# Bot token from @BotFather – used to sign initData locally so the backend
# accepts it without needing a real Telegram session.
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhiJklmNoPQrsTUVwxyz

# @username of the bot (without @), used to build t.me links
TELEGRAM_BOT_USERNAME=airbagshop_bot

# ─── Simulated Telegram users ─────────────────────────────────────────────────
# A Telegram user NOT linked to any site account → expect guest session
TELEGRAM_GUEST_USER_ID=111222333
TELEGRAM_GUEST_USER_FIRST_NAME=TestGuest
TELEGRAM_GUEST_USERNAME=test_guest_user

# A Telegram user whose ID is already saved in the DB under SITE_LINKED_EMAIL
# Used in test 02 to verify auto-login as a real user
TELEGRAM_LINKED_USER_ID=444555666

# ─── Real Telegram session (optional) ─────────────────────────────────────────
# Only needed for the web.telegram.org setup script
# (tests/e2e/setup/telegram-login.setup.ts).
# Run:  npx playwright test --project=telegram-session-setup --headed
# After that the session is saved and these vars are no longer needed at runtime.
TELEGRAM_PHONE=+380XXXXXXXXX
TELEGRAM_CLOUD_PASSWORD=
